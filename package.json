{
  "name": "rn-ui-kit-workspace",
  "version": "1.0.3",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "overrides": {
    "@babel/runtime": "7.29.7"
  },
  "scripts": {
    "build": "bun --cwd packages/rn-ui-kit build",
    "package-release": "node scripts/package-release.js",
    "set-version": "node scripts/set-version.js",
    "typecheck": "bun --cwd packages/rn-ui-kit typecheck && bun --cwd examples/app typecheck"
  }
}
