{
  "name": "rn-ui-kit-workspace",
  "version": "1.1.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "overrides": {
    "@babel/runtime": "7.29.7"
  },
  "scripts": {
    "build": "bun --cwd packages/rn-ui-kit build",
    "package-release": "node scripts/release/package.js",
    "release:android-apk": "node scripts/android/release-example-apk.js",
    "release:notes": "node scripts/release/generate-notes.js",
    "set-version": "node scripts/release/set-version.js",
    "typecheck": "bun --cwd packages/rn-ui-kit typecheck && bun --cwd examples/app typecheck"
  }
}
