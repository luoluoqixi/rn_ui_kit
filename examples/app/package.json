{
  "name": "rn-ui-kit-example",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild:android": "npx expo prebuild --platform android",
    "prebuild:ios": "npx expo prebuild --platform ios",
    "build:android": "expo run:android --variant release --device --no-bundler",
    "build:ios": "expo run:ios --configuration Release --device --no-bundler",
    "typecheck": "tsc --noEmit --pretty false",
    "sync-patches": "rn-ui-sync-patches"
  },
  "dependencies": {
    "@expo/metro-runtime": "=6.1.2",
    "@expo/ui": "=55.0.17",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@lodev09/react-native-true-sheet": "=3.11.1",
    "@react-native-menu/menu": "=2.0.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/elements": "^2.9.26",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@react-navigation/stack": "^7.10.6",
    "@shopify/flash-list": "^2.3.2",
    "expo": "=55.0.26",
    "expo-haptics": "=55.0.14",
    "expo-modules-core": "=55.0.25",
    "expo-status-bar": "=55.0.6",
    "react": "=19.2.5",
    "react-dom": "=19.2.5",
    "react-native": "=0.83.9",
    "react-native-gesture-handler": "=2.31.1",
    "react-native-reanimated": "=4.3.0",
    "react-native-safe-area-context": "=5.7.0",
    "react-native-screens": "=4.24.0",
    "react-native-svg": "^15.15.5",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "=0.21.2",
    "react-native-worklets": "=0.8.1",
    "rn_ui_kit": "workspace:*",
    "rn_ui_kit_debug": "workspace:*",
    "tamagui": "=2.4.0",
    "zeego": "=3.0.6"
  },
  "devDependencies": {
    "@tamagui/babel-plugin": "=2.4.0",
    "@types/react": "=19.2.16",
    "babel-preset-expo": "^55.0.22",
    "typescript": "=5.9.2"
  },
  "patchedDependencies": {
    "@expo/ui@55.0.17": "examples/app/node_modules/rn_ui_kit/patches/@expo+ui@55.0.17.patch",
    "@gorhom/bottom-sheet@5.2.14": "examples/app/node_modules/rn_ui_kit/patches/@gorhom+bottom-sheet@5.2.14.patch",
    "@lodev09/react-native-true-sheet@3.11.1": "examples/app/node_modules/rn_ui_kit/patches/@lodev09+react-native-true-sheet@3.11.1.patch",
    "@react-native-picker/picker@2.11.4": "examples/app/node_modules/rn_ui_kit/patches/@react-native-picker+picker@2.11.4.patch",
    "@tamagui/create-menu@2.4.0": "examples/app/node_modules/rn_ui_kit/patches/@tamagui+create-menu@2.4.0.patch",
    "@tamagui/dialog@2.4.0": "examples/app/node_modules/rn_ui_kit/patches/@tamagui+dialog@2.4.0.patch",
    "@tamagui/native@2.4.0": "examples/app/node_modules/rn_ui_kit/patches/@tamagui+native@2.4.0.patch",
    "@tamagui/portal@2.4.0": "examples/app/node_modules/rn_ui_kit/patches/@tamagui+portal@2.4.0.patch",
    "@tamagui/toast@2.4.0": "examples/app/node_modules/rn_ui_kit/patches/@tamagui+toast@2.4.0.patch",
    "@tamagui/web@2.4.0": "examples/app/node_modules/rn_ui_kit/patches/@tamagui+web@2.4.0.patch",
    "expo-haptics@55.0.14": "examples/app/node_modules/rn_ui_kit/patches/expo-haptics@55.0.14.patch",
    "react-native-reanimated@4.3.0": "examples/app/node_modules/rn_ui_kit/patches/react-native-reanimated@4.3.0.patch",
    "zeego@3.0.6": "examples/app/node_modules/rn_ui_kit/patches/zeego@3.0.6.patch"
  }
}
