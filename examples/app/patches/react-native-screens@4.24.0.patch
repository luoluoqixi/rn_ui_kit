# react-native-screens 补丁：
# - iOS 26：UINavigationBar.tintColor 不会稳定传递给系统返回指示图；通过
#   UINavigationBarAppearance 设置已按主题色渲染的指示图，保留原生 back item、
#   Liquid Glass、长按导航历史与系统返回手势。
diff --git a/ios/RNSScreenStackHeaderConfig.mm b/ios/RNSScreenStackHeaderConfig.mm
index 63845cd..8bc1161 100644
--- a/ios/RNSScreenStackHeaderConfig.mm
+++ b/ios/RNSScreenStackHeaderConfig.mm
@@ -536,6 +536,17 @@ namespace react = facebook::react;
   UIImage *backButtonImage = [config loadBackButtonImageInViewController:vc];
   if (backButtonImage) {
     [appearance setBackIndicatorImage:backButtonImage transitionMaskImage:backButtonImage];
+#if RNS_IPHONE_OS_VERSION_AVAILABLE(26_0)
+  } else if (@available(iOS 26.0, *)) {
+    // On iOS 26 the system-generated back indicator does not reliably inherit
+    // UINavigationBar.tintColor. Supplying an always-original indicator keeps
+    // the native back item and its menu while preserving the configured color.
+    UIImageSymbolConfiguration *symbolConfig =
+        [UIImageSymbolConfiguration configurationWithPointSize:17 weight:UIImageSymbolWeightSemibold];
+    UIImage *maskImage = [UIImage systemImageNamed:@"chevron.backward" withConfiguration:symbolConfig];
+    UIImage *tintedImage = [maskImage imageWithTintColor:config.color renderingMode:UIImageRenderingModeAlwaysOriginal];
+    [appearance setBackIndicatorImage:tintedImage transitionMaskImage:maskImage];
+#endif
   } else if (appearance.backIndicatorImage) {
     [appearance setBackIndicatorImage:nil transitionMaskImage:nil];
   }
