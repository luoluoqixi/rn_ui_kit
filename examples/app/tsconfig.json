{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "declaration": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "rn_ui_kit": [
        "../../packages/rn_ui_kit/src/index.ts"
      ],
      "rn_ui_kit_debug": [
        "../../packages/rn_ui_kit_debug/src/index.ts"
      ],
      "rn_ui_kit/tamagui.config": [
        "../../packages/rn_ui_kit/tamagui.config.ts"
      ]
    }
  },
  "include": [
    "App.tsx",
    "app.config.ts",
    "tamagui.config.ts",
    "themes.ts",
    "*.js",
    "../../packages/rn_ui_kit/src/**/*.ts",
    "../../packages/rn_ui_kit/src/**/*.tsx",
    "../../packages/rn_ui_kit_debug/src/**/*.ts",
    "../../packages/rn_ui_kit_debug/src/**/*.tsx",
    "../../packages/rn_ui_kit/tamagui.config.ts",
    "../../packages/rn_ui_kit/tamagui.build.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
